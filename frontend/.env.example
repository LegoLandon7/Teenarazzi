# Optional override. If omitted, the app uses the default deployed backend.
VITE_SUBMISSIONS_API_BASE=https://replace-with-your-worker.workers.dev

# Optional override for public users feed (defaults to api.teenarazzi.com).
VITE_USERS_API_BASE=https://api.teenarazzi.com

# Optional local-dev switch. Keep false in production to ensure backend is the source of truth.
VITE_ALLOW_STATIC_USERS_FALLBACK=false

# Optional. If set, the apply form requires Cloudflare Turnstile completion.
VITE_TURNSTILE_SITE_KEY=
